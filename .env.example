# Vercel access token with permission to read projects, create Connect
# connectors, and update project settings. Used server-side only — never
# exposed to the browser.
#
# Create this token in Account Settings → Tokens and scope it to your team(s).
# Tokens scoped to one team automatically target that team, making VERCEL_TEAM_ID 
# and VERCEL_TEAM_SLUG below optional.
VERCEL_ACCESS_TOKEN=

# Admin dashboard lists projects scoped to this team.
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=

# Default connector identity used when the admin dashboard attaches Passport
# to a project. Name/UID get a timestamp suffix automatically to avoid clashes.
CONNECTOR_TYPE=oauth
CONNECTOR_SERVICE=
CONNECTOR_NAME=Company Intranet SSO

# OAuth/OIDC connector data for POST /v1/connect/connectors.
# Register this redirect URI with your identity provider:
# https://connect.vercel.com/callback
CONNECTOR_DATA={"serverUrl":"https://example.okta.com/","serverConfig":{"issuer":"https://example.okta.com","authorization_endpoint":"https://example.okta.com/oauth2/v1/authorize","token_endpoint":"https://example.okta.com/oauth2/v1/token","userinfo_endpoint":"https://example.okta.com/oauth2/v1/userinfo","jwks_uri":"https://example.okta.com/oauth2/v1/keys"},"clientId":"","clientSecret":"","tokenEndpointAuthMethod":"client_secret_post","responseType":"code","pkceRequired":false,"userAuthorization":{"enabled":true,"scopes":["openid","email","profile"]},"refreshTokens":{"enabled":false},"clientCredentials":{"enabled":false,"scopes":[]}}
